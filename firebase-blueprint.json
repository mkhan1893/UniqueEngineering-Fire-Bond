{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Industrial fire safety product",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Product name"
        },
        "description": {
          "type": "string",
          "description": "Technical product description"
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL of the product image stored in Firebase Storage"
        },
        "category": {
          "type": "string",
          "description": "Primary grouping for the product"
        },
        "subcategory": {
          "type": "string",
          "description": "Secondary grouping within a category"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of product creation"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of last update"
        }
      },
      "required": ["name", "description", "imageUrl", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of fire safety products managed by the admin"
    }
  }
}
